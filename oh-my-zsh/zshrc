# ==========================================================
#  zshrc — Paweł Owczarczyk (Fedora 43, ThinkPad T490)
#  • UV, Mise, NVM, Cargo, Go, Podman, Kind
# ==========================================================

# --- PATH & ENV ---
export PATH="$HOME/.cargo/bin:$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

# Bitwarden SSH Agent
if [[ -S "$HOME/.bitwarden-ssh-agent.sock" ]]; then
    export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"
elif [[ -S "$HOME/.config/Bitwarden/ssh-agent.sock" ]]; then
    export SSH_AUTH_SOCK="$HOME/.config/Bitwarden/ssh-agent.sock"
fi

# --- NIX ---
if [ -e ~/.nix-profile/share/zsh/site-functions ]; then
     fpath=(~/.nix-profile/share/zsh/site-functions $fpath)
fi

# Go & Krew
export GOPATH="$HOME/.go"
export PATH="$GOPATH/bin:${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

export SHELL="/usr/bin/zsh"
export EDITOR="nvim"
export VISUAL="$EDITOR"

# OpenTofu as Terragrunt backend
export TERRAGRUNT_TFPATH="tofu"

# Kind + Podman Integration
export KIND_EXPERIMENTAL_PROVIDER=podman

# --- Oh-My-Zsh ---
export ZSH="$HOME/.oh-my-zsh"

# Dodaj folder z uzupełnieniami (kind, etc.) do fpath ZANIM załadujesz OMZ
fpath=(~/.oh-my-zsh/completions $fpath)

ZCACHEDIR="${ZDOTDIR:-$HOME}/.zcompcache"
mkdir -p "$ZCACHEDIR"
export ZSH_COMPDUMP="$ZCACHEDIR/.zcompdump"

ZSH_THEME="whoami-fino-time"
CASE_SENSITIVE="false"
DISABLE_MAGIC_FUNCTIONS="true"
ENABLE_CORRECTION="false"
DISABLE_UNTRACKED_FILES_DIRTY="true"

zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 7

plugins=(
  git
  git-prompt
  zsh-autosuggestions
  fast-syntax-highlighting
  zsh-interactive-cd
  fzf
  rust
  mise
  dnf
  nvm
  nix-shell
)

source "$ZSH/oh-my-zsh.sh"

# --- Completion System Init (Critical for tools) ---
autoload -Uz compinit && compinit
autoload -U +X bashcompinit && bashcompinit

# --- History & Options ---
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=200000
export SAVEHIST=200000

setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS
setopt EXTENDED_GLOB
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_VERIFY
setopt SHARE_HISTORY INC_APPEND_HISTORY
setopt INTERACTIVE_COMMENTS
export WORDCHARS='*?[]~=&;!#$%^(){}<>'

# --- fzf & fd (Zoptymalizowane pod Fedorę) ---
if command -v fd >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
fi

if command -v fzf >/dev/null 2>&1; then
    export FZF_CTRL_R_OPTS='--preview "echo {}" --preview-window=down:3:hidden:wrap --bind=?:toggle-preview'
fi

# --- Aliases & Tools ---
alias kubectl='kubecolor'
alias k='kubectl'
alias kubectx='kubie ctx'
alias kubens='kubie ns'
alias kd='kind 2>/dev/null'
alias v="nvim"
alias s='ssh'
alias op='openstack'
alias yz='yazi'
alias logir='sudo systemctl restart logid'

# Odkurzacz - wersja pod Fedorę (DNF + Flatpak + Podman)
alias odkurzacz='sudo dnf autoremove -y && sudo dnf clean all && flatpak uninstall --unused -y && sudo journalctl --vacuum-time=1d && podman system prune -a -f && fstrim -va'

# --- Infrastructure & Kubernetes Completions ---
if command -v kubectl >/dev/null 2>&1; then
    source <(kubectl completion zsh)
    compdef kubecolor=kubectl
fi

if command -v kind >/dev/null 2>&1; then
    source <(kind completion zsh)
fi

# Dynamiczne uzupełniania dla HashiCorp & OpenTofu
for tool in vault terraform tofu terragrunt packer; do
    _path=$(command -v $tool)
    if [ -n "$_path" ]; then
        complete -o nospace -C "$_path" $tool
    fi
done

# AWS CLI completion
if command -v aws >/dev/null 2>&1; then
    complete -C "$(command -v aws_completer)" aws
fi

alias tg='terragrunt'
compdef tg=terragrunt 2>/dev/null
unset _path tool

# --- OpEnv (OpenStack CLI + UV/Venv) ---
openv() {
    local OS_VENV="$HOME/.config/openstack/.venv"

    if [[ "$VIRTUAL_ENV" != "$OS_VENV" ]]; then
        if [[ -f "$OS_VENV/bin/activate" ]]; then
            export VIRTUAL_ENV_DISABLE_PROMPT=1
            source "$OS_VENV/bin/activate"
        else
            echo "󱄊 Error: venv not found. Try: uv venv $OS_VENV --python 3.12"
            return 1
        fi
    fi

    local selected_cloud=$(yq -r '.clouds | keys[]' "$HOME/.config/openstack/clouds.yaml" 2>/dev/null | \
        fzf --height 40% --reverse --cycle --border rounded --prompt="󱇩 Select Project: ")

    if [ -n "$selected_cloud" ]; then
        export OS_CLOUD="$selected_cloud"
        echo "󱇩 Activated: $OS_CLOUD"
    else
        echo "󰜺 Canceled."
    fi
}

opexit() {
    if command -v deactivate >/dev/null 2>&1; then
        deactivate
    fi
    unset OS_CLOUD
    echo "󱇩 OpenStack environment cleared."
}

# --- Modern Coreutils ---
if command -v eza >/dev/null 2>&1; then
    alias ls='eza --group-directories-first --icons'
    alias ll='eza -l --git --group-directories-first --icons'
    alias la='eza -la --git --group-directories-first --icons'
fi

if command -v bat >/dev/null 2>&1; then
    export PAGER="bat"
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

# --- Tools Init & Dynamic Completions ---
[ -n "$(command -v zoxide)" ] && eval "$(zoxide init zsh)"
[ -n "$(command -v direnv)" ] && eval "$(direnv hook zsh)"

# Mise (Init & Completions)
if command -v mise >/dev/null 2>&1; then
    eval "$(mise activate zsh)"
    eval "$(mise completion zsh)"
fi

# UV (Completions)
command -v uv >/dev/null 2>&1 && eval "$(uv generate-shell-completion zsh)"

# --- Fastfetch ---
if [ -t 1 ] && [ -z "$TMUX" ] && command -v fastfetch >/dev/null 2>&1; then
    fastfetch -c "$HOME/.fastfetch/presets/examples/12.jsonc" 2>/dev/null || fastfetch
fi

# --- ☁️  Cloud Management (OneDrive & Google Drive) ---

CL_FLAGS=(
  --vfs-cache-mode full
  --vfs-cache-max-age 48h
  --vfs-cache-max-size 20G
  --timeout 10s
  --daemon
)

# --- ☁️  Cloud Management (OneDrive & Google Drive) ---

CL_FLAGS=(
  --vfs-cache-mode full
  --vfs-cache-max-age 48h
  --vfs-cache-max-size 20G
  --timeout 10s
  --daemon
)

alias cloud-onedrive='mkdir -p ~/Cloud/OneDrive && rclone mount OneDrive: ~/Cloud/OneDrive ${CL_FLAGS[@]} && echo "󰀸 OneDrive mounted in ~/Cloud/OneDrive"'
alias cloud-google='mkdir -p ~/Cloud/GoogleDrive && rclone mount GoogleDrive: ~/Cloud/GoogleDrive ${CL_FLAGS[@]} && echo " Google Drive mounted in ~/Cloud/GoogleDrive"'
alias cloud-on='cloud-onedrive && cloud-google && echo "󰅟 All clouds are now synchronized (VFS Cache)"'
alias cloud-off='fusermount -u ~/Cloud/OneDrive 2>/dev/null; fusermount -u ~/Cloud/GoogleDrive 2>/dev/null && echo "󱊟 Clouds unmounted, caches preserved"'
alias cloud-status='echo "󱇦 Active Mounts:"; mount | grep rclone || echo "   󰈆 No active cloud mounts."; echo "\n󰋊 Cache Usage:"; du -sh ~/.cache/rclone 2>/dev/null || echo "   󰇝 Cache is empty."'

# --- Keybindings ---
bindkey '^?' backward-delete-char
bindkey '^[b' backward-word
bindkey '^[f' forward-word
bindkey '^[[1;3D' backward-word
bindkey '^[[1;3C' forward-word
bindkey '^W' backward-kill-word
bindkey '^[[H' beginning-of-line
bindkey '^[[F' end-of-line

# --- NVM (Lazy Load by Plugin, so these lines can stay for direct access) ---
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
